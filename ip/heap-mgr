#!/usr/bin/env python3
"""Isabelle heap directory manager.

Commands:
    heap-mgr find  [--heaps PREFIX] -- isabelle build ...
    heap-mgr find  [--heaps PREFIX] -- "$(make -Bn target)"
    heap-mgr list  [--heaps PREFIX]
    heap-mgr show  <heap-directory>
    heap-mgr remove <heap-directory>
"""

import argparse
import glob
import os
import re
import shlex
import shutil
import subprocess
import sys

# ANSI colors
GREEN = "\033[32m"
RED = "\033[31m"
YELLOW = "\033[33m"
CYAN = "\033[36m"
BOLD = "\033[1m"
DIM = "\033[2m"
RESET = "\033[0m"

CHECK = f"{GREEN}✓{RESET}"
CROSS = f"{RED}✗{RESET}"
ARROW = f"{CYAN}→{RESET}"


def fmt_size(nbytes):
    for unit in ("B", "KiB", "MiB", "GiB"):
        if nbytes < 1024:
            return f"{nbytes:.1f} {unit}" if unit != "B" else f"{nbytes} {unit}"
        nbytes /= 1024
    return f"{nbytes:.1f} TiB"


def dir_size(path):
    total = 0
    for dirpath, _, filenames in os.walk(path):
        for f in filenames:
            fp = os.path.join(dirpath, f)
            try:
                total += os.path.getsize(fp)
            except OSError:
                pass
    return total


def get_heap_base(args, isabelle_bin=None):
    """Resolve heap base from --heaps or ISABELLE_HOME_USER/heaps."""
    if args.heaps:
        return os.path.abspath(args.heaps)
    isa = isabelle_bin or find_isabelle()
    if not isa:
        sys.exit(f"{RED}Error: cannot find isabelle binary; use --heaps{RESET}")
    try:
        r = subprocess.run([isa, "getenv", "-b", "ISABELLE_HOME_USER"],
                           capture_output=True, text=True, timeout=10)
        home_user = r.stdout.strip()
    except Exception as e:
        sys.exit(f"{RED}Error: could not determine ISABELLE_HOME_USER: {e}{RESET}")
    if not home_user:
        sys.exit(f"{RED}Error: ISABELLE_HOME_USER is empty{RESET}")
    return os.path.abspath(os.path.join(home_user, "heaps"))


def find_isabelle():
    """Try to find isabelle on PATH or in /Applications."""
    for p in ["/Applications/Isabelle2025-2.app/bin/isabelle",
              "/Applications/Isabelle2025.app/bin/isabelle"]:
        if os.path.isfile(p):
            return p
    return shutil.which("isabelle")


def get_candidates(heap_base):
    return sorted(d for d in glob.glob(heap_base + "*") if os.path.isdir(d))


# ---------------------------------------------------------------------------
# find
# ---------------------------------------------------------------------------

def to_build_cmd(cmd):
    """Convert an isabelle command to a dry-run build command."""
    cmd = list(cmd)
    sub_idx = None
    for i, arg in enumerate(cmd):
        if arg in ("build", "jedit"):
            sub_idx = i
            break
    if sub_idx is None:
        sys.exit(f"{RED}Error: command must contain 'build' or 'jedit'{RESET}")

    isabelle = cmd[:sub_idx]

    def extract_args(args):
        clean = []
        i = 0
        while i < len(args):
            if args[i] == "-o" and i + 1 < len(args):
                if args[i + 1].startswith("ML_platform="):
                    clean.extend(["-o", args[i + 1]])
                i += 2
            elif args[i] == "--":
                i += 1
            else:
                clean.append(args[i])
                i += 1
        return clean

    if cmd[sub_idx] == "build":
        return isabelle + ["build", "-n", "-v"] + extract_args(cmd[sub_idx + 1:])

    jedit_args = cmd[sub_idx + 1:]
    dirs, opts, logic = [], [], None
    i = 0
    while i < len(jedit_args):
        if jedit_args[i] == "-d" and i + 1 < len(jedit_args):
            dirs.append(jedit_args[i + 1]); i += 2
        elif jedit_args[i] == "-l" and i + 1 < len(jedit_args):
            logic = jedit_args[i + 1]; i += 2
        elif jedit_args[i] == "-o" and i + 1 < len(jedit_args):
            if jedit_args[i + 1].startswith("ML_platform="):
                opts.extend(["-o", jedit_args[i + 1]])
            i += 2
        else:
            i += 1
    if not logic:
        sys.exit(f"{RED}Error: isabelle jedit command must have -l NAME{RESET}")
    build = isabelle + ["build", "-n", "-v", "-b"] + opts
    for d in dirs:
        build.extend(["-d", d])
    build.append(logic)
    return build


def parse_unfinished(output):
    order = []
    for line in output.splitlines():
        m = re.match(r"Skipping (\S+) \.\.\.", line)
        if m:
            order.append(m.group(1))
    unfinished_set = set()
    for line in output.splitlines():
        m = re.match(r"Unfinished session\(s\): (.+)", line)
        if m:
            unfinished_set = {s.strip() for s in m.group(1).split(",")}
            break
    if not unfinished_set:
        return []
    result = [s for s in order if s in unfinished_set]
    remaining = [s for s in unfinished_set if s not in result]
    return result + sorted(remaining)


def parse_isabelle_cmd(lines):
    """Extract isabelle command from a list of lines."""
    for line in lines:
        line = line.strip()
        if not line:
            continue
        if "isabelle build" in line or "isabelle jedit" in line:
            try:
                return shlex.split(line), lines
            except ValueError:
                return line.split(), lines
    return None, lines


def cmd_find(args, extra):
    """Find the best matching heap directory for an isabelle command."""
    if "--" not in sys.argv:
        sys.exit(f"Usage: heap-mgr find [--heaps PREFIX] -- <isabelle command>\n"
                 f"       heap-mgr find [--heaps PREFIX] -- \"$(make -Bn target)\"")

    sep = sys.argv.index("--")
    rest = sys.argv[sep + 1:]
    if not rest:
        sys.exit(f"{RED}Error: no isabelle command after --{RESET}")

    # Support quoted multi-line input: -- "$(make -Bn ...)"
    lines = " ".join(rest).splitlines()
    user_cmd, lines = parse_isabelle_cmd(lines)

    if not user_cmd:
        print(f"{RED}Error: no 'isabelle build' or 'isabelle jedit' found in input:{RESET}")
        for line in (lines or []):
            print(f"  {DIM}{line}{RESET}")
        sys.exit(1)

    heap_base = get_heap_base(args, isabelle_bin=user_cmd[0])
    candidates = get_candidates(heap_base)

    print(f"\n{BOLD}Isabelle Heap Finder{RESET}")
    print(f"{'─' * 60}")
    print(f"  Heap base:  {heap_base}")

    build_cmd = to_build_cmd(user_cmd)
    print(f"  Command:    {DIM}{' '.join(build_cmd)}{RESET}")

    if candidates:
        print(f"  Candidates: {BOLD}{len(candidates)}{RESET}")
        for d in candidates:
            print(f"              {DIM}{d}{RESET}")
    else:
        print(f"  Candidates: {YELLOW}none matching {heap_base}*{RESET}")

    results = []
    ml_id = ""

    def suffix_of(d):
        return d[len(heap_base):]

    def print_suffix(d):
        print(f"  export ISABELLE_HEAP_SUFFIX='{suffix_of(d)}'\n")

    print(f"\n{'─' * 60}")
    for d in candidates:
        env = {**os.environ, "ISABELLE_HEAPS_OVERRIDE": d}
        label = os.path.basename(d)
        print(f"\n  {BOLD}{label}{RESET}  {DIM}{d}{RESET}")
        result = subprocess.run(build_cmd, env=env, capture_output=True, text=True)
        out = (result.stdout.strip() + "\n" + result.stderr.strip()).strip()

        if not ml_id:
            m = re.search(r'\((\S+) on ', out)
            if m:
                ml_id = m.group(1)
        if result.returncode == 0:
            print(f"  {CHECK} All heaps up to date\n")
            print(f"{'─' * 60}")
            print(f"\n{GREEN}{BOLD}Match found!{RESET}\n")
            print_suffix(d)
            sys.exit(0)
        else:
            unfinished = parse_unfinished(out)
            if unfinished:
                results.append((d, len(unfinished), unfinished))
                print(f"  {CROSS} Needs rebuilding: {YELLOW}{' → '.join(unfinished)}{RESET}")
            else:
                results.append((d, 999, []))
                print(f"  {CROSS} Failed (rc={result.returncode})")
                for line in out.splitlines()[:3]:
                    print(f"    {DIM}{line}{RESET}")

    print(f"\n{'─' * 60}")
    print(f"\n{RED}{BOLD}No exact match found.{RESET}\n")

    if not results:
        sys.exit(1)

    if ml_id:
        print(f"  {DIM}ML identifier: {ml_id}{RESET}")

    best_count = min(r[1] for r in results)
    best_matches = [(d, n, s) for d, n, s in results if n == best_count and s]

    i = 1
    while True:
        new_dir = f"{heap_base}-{i}"
        if not os.path.exists(new_dir):
            break
        i += 1

    if not best_matches:
        print(f"  {ARROW} Fresh directory:\n")
        print_suffix(new_dir)
        sys.exit(1)

    print(f"  Closest match{'es' if len(best_matches) > 1 else ''} "
          f"({YELLOW}{best_count}{RESET} session(s) to rebuild):\n")
    for i, (d, n, sessions) in enumerate(best_matches):
        label = os.path.basename(d)
        idx = f"  [{i + 1}] " if len(best_matches) > 1 else "  "
        print(f"{idx}{BOLD}{label}{RESET}  {DIM}{d}{RESET}")
        print(f"      Rebuild: {DIM}{' → '.join(sessions)}{RESET}")

    # Interactive
    print()
    print(f"  Options:")
    print(f"    {BOLD}u{RESET})se one of the existing heap directories")
    print(f"    {BOLD}c{RESET})lone one into a new directory")
    print(f"    {BOLD}n{RESET})o action")
    action = input(f"\n  [u/c/N] ").strip().lower()

    if action == "u":
        if len(best_matches) == 1:
            source_dir = best_matches[0][0]
        else:
            choice = input(f"  Which? [1-{len(best_matches)}] ").strip()
            try:
                source_dir = best_matches[int(choice) - 1][0]
            except (ValueError, IndexError):
                print(f"\n  {DIM}No changes made.{RESET}\n")
                sys.exit(1)
        print(f"\n  export ISABELLE_HEAP_SUFFIX='{suffix_of(source_dir)}'\n")
        sys.exit(0)

    if action != "c":
        print(f"\n  {DIM}No changes made.{RESET}\n")
        sys.exit(1)

    if len(best_matches) == 1:
        source_dir = best_matches[0][0]
    else:
        choice = input(f"  Clone which? [1-{len(best_matches)}] ").strip()
        try:
            source_dir = best_matches[int(choice) - 1][0]
        except (ValueError, IndexError):
            print(f"\n  {DIM}No changes made.{RESET}\n")
            sys.exit(1)

    src_platform = os.path.join(source_dir, ml_id) if ml_id else source_dir
    dst_platform = os.path.join(new_dir, ml_id) if ml_id else new_dir

    print(f"\n  {BOLD}This will:{RESET}")
    if ml_id and os.path.isdir(src_platform):
        cmds = [f"mkdir -p {dst_platform}", f"cp -a {src_platform}/* {dst_platform}/"]
    else:
        cmds = [f"cp -a {source_dir} {new_dir}"]
    for cmd in cmds:
        print(f"    $ {cmd}")

    answer = input(f"\n  Proceed? [y/N] ").strip().lower()
    if answer != "y":
        print(f"\n  {DIM}No changes made.{RESET}\n")
        sys.exit(1)

    print()
    for cmd in cmds:
        print(f"    $ {cmd}")
        os.system(cmd)

    print(f"\n  {GREEN}{BOLD}Done.{RESET}\n")
    print_suffix(new_dir)
    sys.exit(0)


