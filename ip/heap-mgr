# list
# ---------------------------------------------------------------------------

def cmd_list(args, extra):
    """List all heap directories matching the prefix."""
    heap_base = get_heap_base(args)
    candidates = get_candidates(heap_base)

    print(f"\n{BOLD}Isabelle Heap Directories{RESET}")
    print(f"{'─' * 60}")
    print(f"  Base: {heap_base}\n")

    if not candidates:
        print(f"  {YELLOW}No directories matching {heap_base}*{RESET}\n")
        return

    for d in candidates:
        label = os.path.basename(d)
        size = fmt_size(dir_size(d))
        # Count platform subdirs and heaps
        subdirs = [s for s in os.listdir(d)
                   if os.path.isdir(os.path.join(d, s)) and not s.startswith(".")]
        heap_count = 0
        for sd in subdirs:
            sd_path = os.path.join(d, sd)
            heaps = [f for f in os.listdir(sd_path)
                     if os.path.isfile(os.path.join(sd_path, f)) and f != "log" and not f.startswith(".")]
            heap_count += len(heaps)

        print(f"  {BOLD}{label}{RESET}  {DIM}{d}{RESET}")
        print(f"    {size}, {len(subdirs)} platform(s), {heap_count} heap(s)")
        for sd in sorted(subdirs):
            sd_path = os.path.join(d, sd)
            heaps = sorted(f for f in os.listdir(sd_path)
                           if os.path.isfile(os.path.join(sd_path, f)) and not f.startswith("."))
            if heaps:
                print(f"    {CYAN}{sd}{RESET}: {DIM}{', '.join(heaps)}{RESET}")
        print()


