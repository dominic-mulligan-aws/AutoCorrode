# remove
# ---------------------------------------------------------------------------

def cmd_remove(args, extra):
    """Remove a heap directory after confirmation."""
    if extra:
        heap_dir = os.path.abspath(extra[0])
        if not os.path.isdir(heap_dir):
            sys.exit(f"{RED}Error: {heap_dir} is not a directory{RESET}")
    else:
        heap_base = get_heap_base(args)
        candidates = get_candidates(heap_base)
        if not candidates:
            sys.exit(f"{RED}No heap directories matching {heap_base}*{RESET}")
        print(f"\n{BOLD}Available heap directories:{RESET}\n")
        for i, d in enumerate(candidates):
            label = os.path.basename(d)
            size = fmt_size(dir_size(d))
            print(f"  [{i + 1}] {BOLD}{label}{RESET}  {DIM}{d}{RESET}  ({size})")
        choice = input(f"\n  Which to remove? [1-{len(candidates)}] ").strip()
        try:
            heap_dir = candidates[int(choice) - 1]
        except (ValueError, IndexError):
            sys.exit(1)

    print(f"\n{RED}{BOLD}Remove heap directory:{RESET} {heap_dir}\n")

    # List contents
    total_files = 0
    total_size = 0
    for dirpath, dirnames, filenames in os.walk(heap_dir):
        for f in filenames:
            fp = os.path.join(dirpath, f)
            try:
                sz = os.path.getsize(fp)
            except OSError:
                sz = 0
            total_files += 1
            total_size += sz
            rel = os.path.relpath(fp, heap_dir)
            print(f"  {DIM}{rel}{RESET}  ({fmt_size(sz)})")

    print(f"\n  {BOLD}{total_files}{RESET} files, {BOLD}{fmt_size(total_size)}{RESET} total\n")

    answer = input(f"  {RED}Delete everything above?{RESET} [y/N] ").strip().lower()
    if answer != "y":
        print(f"\n  {DIM}No changes made.{RESET}\n")
        return

    shutil.rmtree(heap_dir)
    print(f"\n  {GREEN}Removed.{RESET}\n")


# ---------------------------------------------------------------------------
# main
# ---------------------------------------------------------------------------

def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help"):
        print(f"""usage: heap-mgr <command> [options]

{BOLD}Tool to help managing multiple Isabelle heap directories.{RESET}

Commands:
  {BOLD}find{RESET}      For a given isabelle command, identify the heap directory
            matching the target most closely.
  {BOLD}list{RESET}      List all heap directories with the given prefix.
  {BOLD}show{RESET}      Show contents of a heap directory (heaps + .db files).
  {BOLD}remove{RESET}    Remove a heap directory (with confirmation).

Run 'heap-mgr <command> --help' for command-specific help.""")
        sys.exit(0)

    command = sys.argv[1]
    commands = {
        "find": (cmd_find, argparse.ArgumentParser(
            prog="heap-mgr find",
            description="For a given isabelle command, identify the heap directory matching the target most closely.",
            epilog="""Examples:
  %(prog)s -- isabelle build -b -d . My_Session
  %(prog)s -- "$(make -Bn my-target)"

The isabelle command follows '--'. If the input contains multiple lines
(e.g. from "$(make -Bn ...)"), it must be quoted so that newlines are
preserved. Lines not containing 'isabelle build' or 'isabelle jedit'
are silently ignored.""",
            formatter_class=argparse.RawDescriptionHelpFormatter)),
        "list": (cmd_list, argparse.ArgumentParser(
            prog="heap-mgr list",
            description="List all heap directories with the given prefix.",
            epilog="""Examples:
  %(prog)s
  %(prog)s --heaps /path/to/heaps""",
            formatter_class=argparse.RawDescriptionHelpFormatter)),
        "show": (cmd_show, argparse.ArgumentParser(
            prog="heap-mgr show",
            description="Show contents of a heap directory (heaps paired with .db files).",
            epilog="""Examples:
  %(prog)s /path/to/heaps-A
  %(prog)s                      (interactive selection)""",
            formatter_class=argparse.RawDescriptionHelpFormatter)),
        "remove": (cmd_remove, argparse.ArgumentParser(
            prog="heap-mgr remove",
            description="Remove a heap directory after listing contents and confirming.",
            epilog="""Examples:
  %(prog)s /path/to/heaps-old""",
            formatter_class=argparse.RawDescriptionHelpFormatter)),
    }

    if command not in commands:
        sys.exit(f"{RED}Unknown command: {command}{RESET}\nAvailable: {', '.join(commands)}")

    func, parser = commands[command]
    parser.add_argument("--heaps", default=None,
                        help="Heap base path prefix (default: $ISABELLE_HOME_USER/heaps)")
    args, extra = parser.parse_known_args(sys.argv[2:])
    func(args, extra)


if __name__ == "__main__":
    main()
