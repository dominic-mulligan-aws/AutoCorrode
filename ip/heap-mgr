# show
# ---------------------------------------------------------------------------

def cmd_show(args, extra):
    """Show contents of a heap directory, pairing heaps with .db files."""
    if extra:
        heap_dir = os.path.abspath(extra[0])
        if not os.path.isdir(heap_dir):
            sys.exit(f"{RED}Error: {heap_dir} is not a directory{RESET}")
    else:
        # Interactive: list candidates and ask
        heap_base = get_heap_base(args)
        candidates = get_candidates(heap_base)
        if not candidates:
            sys.exit(f"{RED}No heap directories matching {heap_base}*{RESET}")
        print(f"\n{BOLD}Available heap directories:{RESET}\n")
        for i, d in enumerate(candidates):
            print(f"  [{i + 1}] {BOLD}{os.path.basename(d)}{RESET}  {DIM}{d}{RESET}")
        choice = input(f"\n  Which? [1-{len(candidates)}] ").strip()
        try:
            heap_dir = candidates[int(choice) - 1]
        except (ValueError, IndexError):
            sys.exit(1)

    print(f"\n{BOLD}Heap Directory: {CYAN}{os.path.basename(heap_dir)}{RESET}")
    print(f"{'─' * 60}")
    print(f"  Path: {DIM}{heap_dir}{RESET}")
    print(f"  Size: {fmt_size(dir_size(heap_dir))}\n")

    import time as _time

    def file_mtime(path):
        try:
            return os.path.getmtime(path)
        except OSError:
            return 0

    def fmt_date(mtime):
        if mtime == 0:
            return ""
        return _time.strftime("%Y-%m-%d %H:%M", _time.localtime(mtime))

    subdirs = [s for s in os.listdir(heap_dir)
               if os.path.isdir(os.path.join(heap_dir, s)) and not s.startswith(".")]

    # Compute max mtime per subdir for sorting
    def subdir_max_mtime(sd):
        sd_path = os.path.join(heap_dir, sd)
        log_dir = os.path.join(sd_path, "log")
        mtimes = []
        for f in os.listdir(sd_path):
            fp = os.path.join(sd_path, f)
            if os.path.isfile(fp):
                mtimes.append(file_mtime(fp))
        if os.path.isdir(log_dir):
            for f in os.listdir(log_dir):
                fp = os.path.join(log_dir, f)
                if os.path.isfile(fp):
                    mtimes.append(file_mtime(fp))
        return max(mtimes) if mtimes else 0

    subdirs.sort(key=subdir_max_mtime, reverse=True)

    for sd in subdirs:
        sd_path = os.path.join(heap_dir, sd)
        log_dir = os.path.join(sd_path, "log")

        # Collect heaps (files in sd_path, not dirs)
        heaps = [f for f in os.listdir(sd_path)
                 if os.path.isfile(os.path.join(sd_path, f)) and not f.startswith(".")]

        # Collect .db files
        dbs = {}
        if os.path.isdir(log_dir):
            for f in os.listdir(log_dir):
                if f.endswith(".db"):
                    name = f[:-3]
                    dbs[name] = os.path.join(log_dir, f)

        print(f"  {BOLD}{sd}{RESET}")

        if not heaps and not dbs:
            print(f"    {DIM}(empty){RESET}")
            print()
            continue

        # All session names, sorted by most recent mtime (heap or db)
        all_sessions = sorted(set(heaps) | set(dbs.keys()),
                              key=lambda s: max(
                                  file_mtime(os.path.join(sd_path, s)) if s in heaps else 0,
                                  file_mtime(dbs[s]) if s in dbs else 0),
                              reverse=True)

        for session in all_sessions:
            heap_path = os.path.join(sd_path, session)
            db_path = dbs.get(session)

            has_heap = session in heaps
            has_db = db_path is not None

            # Most recent mtime of heap or db
            mtime = max(file_mtime(heap_path) if has_heap else 0,
                        file_mtime(db_path) if has_db else 0)
            date_str = fmt_date(mtime)

            heap_info = ""
            if has_heap:
                heap_size = fmt_size(os.path.getsize(heap_path))
                heap_info = f"heap={heap_size}"

            db_info = ""
            if has_db:
                db_size = fmt_size(os.path.getsize(db_path))
                db_info = f"db={db_size}"

            parts = [p for p in [heap_info, db_info] if p]
            if has_heap and has_db:
                status = CHECK
            elif has_heap and not has_db:
                status = f"{YELLOW}!{RESET}"
                parts.append(f"{YELLOW}no .db{RESET}")
            elif has_db and not has_heap:
                status = f"{YELLOW}!{RESET}"
                parts.append(f"{YELLOW}no heap{RESET}")
            else:
                status = f"{RED}?{RESET}"

            print(f"    {status} {BOLD}{session:{30}}{RESET} {DIM}{date_str}  {', '.join(parts)}{RESET}")
            if has_db:
                print(f"         {DIM}{db_path}{RESET}")
            elif has_heap:
                print(f"         {DIM}(no .db){RESET}")

        print()

    print(f"  {DIM}Use 'heap-db-inspect <file.db>' to inspect a .db file in detail.{RESET}\n")


